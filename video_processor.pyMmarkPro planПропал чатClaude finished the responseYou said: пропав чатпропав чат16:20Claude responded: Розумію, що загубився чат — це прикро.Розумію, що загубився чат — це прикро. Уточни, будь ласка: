import os
import subprocess
import random
import logging
import whisper

logger = logging.getLogger(__name__)

SUBTITLE_STYLES = [
    {"name": "white_bold_bottom", "fontcolor": "white", "fontsize": 18, "position": "bottom"},
    {"name": "yellow_top", "fontcolor": "yellow", "fontsize": 20, "position": "top"},
    {"name": "white_outline_center", "fontcolor": "white", "fontsize": 22, "position": "center"},
    {"name": "green_bottom", "fontcolor": "#00FF00", "fontsize": 18, "position": "bottom"},
    {"name": "white_big_bottom", "fontcolor": "white", "fontsize": 26, "position": "bottom"},
    {"name": "red_top", "fontcolor": "#FF4444", "fontsize": 20, "position": "top"},
]

AUDIO_FILTERS = [
    "atempo=1.02",
    "aecho=0.8:0.88:20:0.4",
    "asetrate=44100*1.02,aresample=44100",
    "atempo=0.98",
    "aecho=0.9:0.85:30:0.3",
    "atempo=1.01,asetrate=44100*1.01,aresample=44100",
]

VIDEO_FILTERS = [
    "eq=brightness=0.05:contrast=1.05",
    "hflip,eq=brightness=0.02",
    "eq=saturation=1.1:brightness=-0.03",
    "setpts=1.02*PTS,eq=contrast=1.08:brightness=0.02",
    "vflip,hflip,eq=saturation=0.95:brightness=0.04",
    "setpts=0.99*PTS,eq=brightness=0.03:contrast=1.03:saturation=1.05,hflip",
]

TRIM_STARTS = [0, 0, 0.5, 0, 0, 0.3]

# Кольори для drawtext субтитрів
FONT_COLORS = [
    "white", "yellow", "white", "green", "white", "red"
]
FONT_POSITIONS = [
    "(w-text_w)/2:h-th-50",   # низ центр
    "(w-text_w)/2:50",         # верх центр
    "(w-text_w)/2:(h-th)/2",  # центр
    "(w-text_w)/2:h-th-50",   # низ центр
    "(w-text_w)/2:h-th-50",   # низ центр
    "(w-text_w)/2:50",         # верх центр
]
FONT_SIZES = [18, 20, 22, 18, 26, 20]


def transcribe_video(input_path):
    print("🎙️  Транскрибую аудіо...", flush=True)
    try:
        model = whisper.load_model("base")
        result = model.transcribe(input_path, word_timestamps=False)
        segments = result.get("segments", [])
        print(f"✅ Знайдено {len(segments)} субтитрів")
        return segments
    except Exception as e:
        print(f"⚠️  Whisper помилка: {e}")
        return []


def build_drawtext_filter(segments, style_idx):
    """Будує drawtext фільтр для кожного сегменту"""
    color = FONT_COLORS[style_idx]
    pos = FONT_POSITIONS[style_idx]
    size = FONT_SIZES[style_idx]
    x_pos, y_pos = pos.split(":")

    filters = []
    for seg in segments:
        start = seg["start"]
        end = seg["end"]
        text = seg["text"].strip().replace("'", "\\'").replace(":", "\\:")
        text = text.replace(",", "\\,")

        dt = (
            f"drawtext=text='{text}'"
            f":fontsize={size}"
            f":fontcolor={color}"
            f":x={x_pos}:y={y_pos}"
            f":box=1:boxcolor=black@0.5:boxborderw=5"
            f":enable='between(t,{start:.2f},{end:.2f})'"
        )
        filters.append(dt)

    return ",".join(filters) if filters else ""


def run_ffmpeg(cmd):
    try:
        result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=600)
        if result.returncode != 0:
            logger.error(f"FFmpeg error: {result.stderr.decode()[-300:]}")
            return False
        return True
    except subprocess.TimeoutExpired:
        return False


def process_video(input_path, output_dir, file_id):
    output_paths = []
    os.makedirs(output_dir, exist_ok=True)

    segments = transcribe_video(input_path)

    for i in range(6):
        output_path = os.path.join(output_dir, f"{file_id}_v{i+1}.mp4")
        style = SUBTITLE_STYLES[i]

        print(f"⚙️  Варіант {i+1}/6 ({style['name']})...", end=" ", flush=True)

        # Будуємо відео фільтр
        vf_parts = [VIDEO_FILTERS[i]]

        if segments:
            dt_filter = build_drawtext_filter(segments, i)
            if dt_filter:
                vf_parts.append(dt_filter)

        vf = ",".join(vf_parts)
        af = AUDIO_FILTERS[i]
        trim_start = TRIM_STARTS[i]

        cmd = ["ffmpeg", "-y"]
        if trim_start > 0:
            cmd += ["-ss", str(trim_start)]
        cmd += ["-i", input_path]
        cmd += ["-vf", vf, "-af", af]
        cmd += [
            "-metadata", f"comment=v{i+1}_{random.randint(100000,999999)}",
            "-c:v", "libx264",
            "-preset", "fast",
            "-crf", str(random.randint(22, 26)),
            "-c:a", "aac",
            "-b:a", "128k",
            output_path
        ]

        success = run_ffmpeg(cmd)

        if success and os.path.exists(output_path):
            output_paths.append(output_path)
            size = os.path.getsize(output_path) / 1024 / 1024
            print(f"✅ {size:.1f} МБ")
        else:
            print("❌ не вдалось")

    return output_paths


def cleanup_outputs(paths):
    for path in paths:
        if os.path.exists(path):
            os.remove(path)
